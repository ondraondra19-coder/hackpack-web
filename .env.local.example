# Doprava — Zásilkovna / Packeta (jediný dopravce — výdejní místa i doručení na adresu)
# NEXT_PUBLIC_PACKETA_API_KEY: veřejný klíč pro widget výdejních míst (zobrazuje se
#   v prohlížeči zákazníka). Získá se registrací na
#   https://client.packeta.com/cs/registration/choose-type (schválení do ~3 dnů),
#   klíč pak najdete po přihlášení kliknutím na jméno vpravo nahoře.
NEXT_PUBLIC_PACKETA_API_KEY=

# PACKETA_API_PASSWORD: soukromé API heslo pro vytváření zásilek (createPacket) —
#   NENÍ totéž co API klíč výše. Ze stejné administrace Packeta.
PACKETA_API_PASSWORD=
